{
  "expo": {
    "name": "LOBO AUTOPARTS",
    "slug": "LOBO AUTOPARTS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo4.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo2.png",
      "resizeMode": "contain",
      "backgroundColor": "#eef2f7"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo2.png",
        "backgroundColor": "#eef2f7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logo4.png"
    },
    "plugins": [
      "expo-video",
      "expo-font"
    ]
  }
}
